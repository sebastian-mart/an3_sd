<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence
http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
             version="2.0"
             xmlns="http://java.sun.com/xml/ns/persistence">
    <persistence-unit name="bazaDeDateSQLite" transaction-type="RESOURCE_LOCAL">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
        <class>ejb.StudentEntity</class>
        <properties>
            <property name="javax.persistence.jdbc.driver" value="org.sqlite.JDBC" />
            <property name="eclipselink.logging.level" value="ALL" />
            <!-- Înlocuiește SQLitePlatform cu DatabasePlatform -->
            <property name="javax.persistence.jdbc.url" value="jdbc:sqlite:/home/sebastian/facultate/an3/sem2/sd/labs/lab2/JEE-App/studenti.db" />
            <property name="eclipselink.ddl-generation" value="create-or-extend-tables" />
        </properties>
    </persistence-unit>
</persistence>